# Copy this file to .env and adjust values
PORT=4000

DB_HOST=localhost
DB_PORT=5432
DB_NAME=pharmastock
DB_USER=postgres
DB_PASSWORD=postgres

# Read by the dockerized Postgres (docker compose db service) — keep in
# sync with the DB_* values above
POSTGRES_DB=pharmastock
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=8h
